# Sentence Transformers (local embeddings - no API needed)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Reranking using Llama inference via HuggingFace
RERANK_TOP_K=3
RERANK_LLM_URL=https://api-inference.huggingface.co/models/meta-llama/Llama-3.2-3B-Instruct

# HF Inference API for LLM and reranking (required)
HF_TOKEN=your_hf_token_here
HF_INFERENCE_URL=https://api-inference.huggingface.co/models/HuggingFaceH4/zephyr-7b-beta

# Vector store: faiss (local) or pinecone (cloud, free tier)
VECTOR_STORE=faiss
FAISS_INDEX_PATH=data/faiss.index
FAISS_METADATA_PATH=data/faiss_metadata.json

# Pinecone (only when VECTOR_STORE=pinecone)
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX=rag-index
PINECONE_ENV=

# Redis (required for background jobs)
REDIS_URL=redis://localhost:6379

# Optional
UPLOAD_DIR=uploads
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K=10
LOG_LEVEL=INFO
